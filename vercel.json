{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://3.36.139.67/api/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "http://3.36.139.67/oauth2/:path*"
    },
    {
      "source": "/login/oauth2/:path*",
      "destination": "http://3.36.139.67/login/oauth2/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
